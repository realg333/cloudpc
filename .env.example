# Database (PostgreSQL). For Supabase + Vercel: use pooler port 6543 + ?pgbouncer=true (see README)
DATABASE_URL="postgresql://user:password@localhost:5432/cloud_gaming_vps"

# Secret for signing session cookies. REQUIRED in production (Vercel).
# Generate: openssl rand -base64 32
SESSION_SECRET=
# Optional: set to 'true' to log session diagnostics; remove in production
# SESSION_DEBUG=true

# Admin: email that gets admin access (runtime check + seed). Case-insensitive.
# ADMIN_EMAIL=admin@example.com

# Email (Resend) - required for verification emails. Get a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional: custom "from" address after verifying your domain (default: onboarding@resend.dev)
# onboarding@resend.dev is test-only; verify domain at https://resend.com/domains for production
# RESEND_FROM_EMAIL="Cloud Gaming VPS <noreply@seudominio.com.br>"

# --- Vercel deployment checklist ---
# APP_URL: public URL (e.g. https://cloudpc.vercel.app) — used when x-forwarded headers missing
# SESSION_SECRET: required; set in Vercel env vars
# RESEND_API_KEY: required for verification emails
# RESEND_FROM_EMAIL: optional; use verified domain for production
# SESSION_DEBUG: optional; set 'true' to diagnose session issues; remove in production

# --- Vultr (required for Phase 10) ---
# Get from Vultr dashboard: https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=
# Max concurrent active VMs (initial cap; override via .env)
VULTR_MAX_ACTIVE_VMS=10
# Windows GPU OS image ID (default 215)
VULTR_WINDOWS_GPU_OS_ID=215
# Grace period in minutes before teardown after expiry
GRACE_PERIOD_MINUTES=5

# --- CRON (required for Vercel Cron) ---
# Random string; Vercel Cron sends x-cron-secret or Authorization: Bearer
CRON_SECRET=

# --- Cost guardrails ---
# Set false or 0 to disable provisioning (kill switch)
PROVISIONING_ENABLED=true

# --- Asaas PIX (required) ---
ASAAS_API_KEY=
# Webhook auth token from Asaas webhook config (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
# Optional: só o host, SEM /v3 no fim (o código já usa .../v3/customers)
# https://api.asaas.com ou https://api-sandbox.asaas.com
# ASAAS_API_BASE_URL=
# CPF/CNPJ digits for first-time Asaas customer creation (required for new users without asaasCustomerId)
# Opcional: fallback se o checkout não enviar CPF/CNPJ (prioridade: campo no PIX → User.cpfCnpj → esta var)
# ASAAS_DEFAULT_CUSTOMER_DOCUMENT=
# Webhook URL: https://your-domain/api/webhooks/payments

# Public app URL (e.g. https://cloudpc.vercel.app). Fallback when x-forwarded headers missing.
# APP_URL=https://your-domain.vercel.app

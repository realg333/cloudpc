# Database (PostgreSQL). For local dev you can use SQLite or PostgreSQL.
DATABASE_URL="postgresql://user:password@localhost:5432/cloud_gaming_vps"

# Secret for signing session cookies. Generate a random string in production.
SESSION_SECRET=

# Email (Resend) - required for verification emails. Get a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional: custom "from" address after verifying your domain (default: onboarding@resend.dev)
# RESEND_FROM_EMAIL="Cloud Gaming VPS <noreply@seudominio.com.br>"

# --- Vultr (required for Phase 10) ---
# Get from Vultr dashboard: https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=
# Max concurrent active VMs (initial cap; override via .env)
VULTR_MAX_ACTIVE_VMS=10
# Windows GPU OS image ID (default 215)
VULTR_WINDOWS_GPU_OS_ID=215
# Grace period in minutes before teardown after expiry
GRACE_PERIOD_MINUTES=5

# --- CRON (required for Vercel Cron) ---
# Random string; Vercel Cron sends x-cron-secret or Authorization: Bearer
CRON_SECRET=

# --- Cost guardrails ---
# Set false or 0 to disable provisioning (kill switch)
PROVISIONING_ENABLED=true

# --- Mercado Pago (Phase 9) ---
# API access token from Mercado Pago dashboard
MERCADOPAGO_ACCESS_TOKEN=
# For webhook signature verification
MERCADOPAGO_WEBHOOK_SECRET=
# Webhook URL: https://your-domain/api/webhooks/payments (replace your-domain with Vercel deployment URL)

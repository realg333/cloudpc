# Database (PostgreSQL). For local dev you can use SQLite or PostgreSQL.
DATABASE_URL="postgresql://user:password@localhost:5432/cloud_gaming_vps"

# Secret for signing session cookies. Generate a random string in production.
SESSION_SECRET=

# Email (Resend) - required for verification emails. Get a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional: custom "from" address after verifying your domain (default: onboarding@resend.dev)
# RESEND_FROM_EMAIL="Cloud Gaming VPS <noreply@seudominio.com.br>"

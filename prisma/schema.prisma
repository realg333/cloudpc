generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  isAdmin        Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  emailVerificationTokens EmailVerificationToken[]
  twoFactorSecret TwoFactorSecret?
  orders         Order[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String?
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
}

model TwoFactorSecret {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret     String
  createdAt  DateTime  @default(now())
  disabledAt DateTime?
}

model MachineProfile {
  id           String   @id @default(cuid())
  name         String   @unique
  gpuTier      String
  ramGb        Int
  cpuSummary   String
  providerType String
  vultrPlanId  String?
  vultrRegion  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  provisionedVms ProvisionedVm[]

  @@index([vultrPlanId])
}

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  durationHours Int
  priceCents    Int      @default(0)
  description   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders        Order[]
}

model Order {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  machineProfileId String
  machineProfile   MachineProfile @relation(fields: [machineProfileId], references: [id], onDelete: Restrict)
  status           String         @default("pending_payment")
  amountCents      Int?
  currency         String?        @default("BRL")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  payments         Payment[]
  provisionedVm    ProvisionedVm?
  provisioningJob  ProvisioningJob?

  @@index([userId])
  @@index([planId])
  @@index([machineProfileId])
}

model ProvisioningJob {
  id             String         @id @default(cuid())
  orderId        String         @unique
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         String         @default("pending")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  provisionedVm  ProvisionedVm?

  @@index([status])
}

model ProvisionedVm {
  id                   String         @id @default(cuid())
  orderId              String         @unique
  order                Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provisioningJobId   String?        @unique
  provisioningJob     ProvisioningJob? @relation(fields: [provisioningJobId], references: [id], onDelete: SetNull)
  status               String
  vultrInstanceId     String?        @unique
  machineProfileId    String
  machineProfile      MachineProfile @relation(fields: [machineProfileId], references: [id], onDelete: Restrict)
  provisioningStartedAt DateTime?
  readyAt             DateTime?
  expiresAt           DateTime?
  destroyedAt         DateTime?
  failureCode         String?
  failureMessage      String?
  lastProviderResponse Json?
  retryCount          Int            @default(0)
  nextRetryAt         DateTime?
  connectionMethod    String?
  connectionState     String?
  connectionMetadata  Json?
  windowsUsername     String?
  secretReference     String?
  ipAddress           String?
  label               String?
  hostname            String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status])
  @@index([vultrInstanceId])
  @@index([expiresAt])
}

model Payment {
  id               String   @id @default(cuid())
  orderId          String   @unique
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gatewayPaymentId String
  amountCents      Int
  currency         String   @default("BRL")
  method           String
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([gatewayPaymentId])
}

model PaymentLog {
  id              String   @id @default(cuid())
  gatewayEventId  String   @unique
  eventType       String
  orderId         String?
  outcome         String
  processedAt     DateTime @default(now())
  metadata        Json?

  @@index([orderId])
}

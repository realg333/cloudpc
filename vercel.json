{
  "github": {
    "autoJobCancelation": false
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/process-teardown",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-provisioning",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reconciliation",
      "schedule": "*/15 * * * *"
    }
  ]
}
